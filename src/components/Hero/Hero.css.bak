/* ===================================
   HERO — ОСНОВНЫЕ СТИЛИ
   =================================== */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: linear-gradient(135deg, #0d0d0d 0%, #1a1a1a 100%);
}

/* ===================================
   АНИМИРОВАННЫЕ ПИКСЕЛИ НА ФОНЕ (CSS)
   =================================== */
.hero__pixels-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  overflow: hidden;
}

.hero__pixel {
  position: absolute;
  bottom: -10px;
  background: var(--accent-yellow);
  border-radius: 0;
  animation: pixelFloat linear infinite;
}

@keyframes pixelFloat {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translateY(-100vh) rotate(360deg);
    opacity: 0;
  }
}

/* ===================================
   ТЁМНЫЙ OVERLAY
   =================================== */
.hero__overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 2;
}

/* ===================================
   КОНТЕНТ HERO
   =================================== */
.hero__content {
  position: relative;
  z-index: 3;
  text-align: center;
  padding: 120px 20px 80px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30px;
}

/* ===================================
   ПОДЗАГОЛОВОК (МАЛЕНЬКИЙ ТЕКСТ СВЕРХУ)
   =================================== */
.hero__subtitle {
  font-family: var(--font-text);
  font-size: clamp(0.85rem, 2vw, 1.1rem);
  font-weight: 500;
  color: var(--text-gray);
  letter-spacing: 2px;
  text-transform: uppercase;
}

/* ===================================
   ЗАГОЛОВОК PIXEL С GLITCH АНИМАЦИЕЙ
   =================================== */
.hero__title {
  font-family: var(--font-pixel);
  font-size: clamp(2.5rem, 8vw, 5rem);
  color: var(--accent-yellow);
  text-shadow: var(--glow-yellow-strong);
  margin: 0;
  line-height: 1.2;
  animation: glitch 2s infinite;
}

/* ===================================
   TYPED.JS — ПЕЧАТАЮЩИЙСЯ ТЕКСТ
   =================================== */
.hero__typed-wrapper {
  min-height: 40px;
}

.hero__typed {
  font-family: var(--font-pixel);
  font-size: clamp(1rem, 3vw, 1.5rem);
  color: var(--text-white);
}

.typed-cursor {
  color: var(--accent-yellow);
  font-size: clamp(1rem, 3vw, 1.5rem);
}

/* ===================================
   ТЕГИ УСЛУГ — ПИКСЕЛЬНЫЕ КАРТОЧКИ
   =================================== */
.hero__tags {
  display: flex;
  flex-wrap: nowrap;
  justify-content: center;
  gap: 16px;
  max-width: 100%;
  overflow-x: auto;
  padding: 10px 0;
}

.hero__tag-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  min-width: 110px;
  padding: 20px 14px;
  background: rgba(26, 26, 26, 0.8);
  border: 2px solid var(--border-glow);
  border-radius: 8px;
  transition: all 0.3s ease;
  cursor: default;
  flex-shrink: 0;
}

.hero__tag-card:hover {
  background: rgba(255, 215, 0, 0.08);
  border-color: var(--accent-yellow);
  box-shadow: 0 0 20px rgba(255, 215, 0, 0.4);
  transform: translateY(-4px);
}

.hero__tag-icon {
  width: 40px;
  height: 40px;
  flex-shrink: 0;
  image-rendering: pixelated;
  filter: drop-shadow(0 0 4px rgba(255, 215, 0, 0.3));
}

.hero__tag-text {
  font-family: var(--font-pixel);
  font-size: 0.55rem;
  color: var(--accent-yellow);
  text-align: center;
  line-height: 1.3;
  text-shadow: 0 0 8px rgba(255, 215, 0, 0.3);
}

/* ===================================
   КНОПКА CTA С ПУЛЬСАЦИЕЙ
   =================================== */
.hero__cta-btn {
  padding: 18px 45px;
  background: var(--accent-yellow);
  color: var(--bg-primary);
  font-weight: 700;
  font-size: clamp(1rem, 2.5vw, 1.2rem);
  border-radius: 8px;
  text-transform: uppercase;
  letter-spacing: 2px;
  box-shadow: var(--glow-yellow-strong);
  transition: all 0.3s ease;
  animation: pulse 2s infinite;
}

.hero__cta-btn:hover {
  background: var(--accent-dark);
  transform: translateY(-4px) scale(1.05);
  box-shadow: 0 0 40px #FFD700, 0 0 80px rgba(255, 215, 0, 0.4);
}

.hero__cta-btn:active {
  transform: translateY(-2px) scale(1.02);
}

/* ===================================
   ИНФОРМАЦИЯ ОБ ОПЛАТЕ
   =================================== */
.hero__payment-info {
  font-size: clamp(0.9rem, 2vw, 1.1rem);
  color: var(--accent-yellow);
  font-weight: 500;
  text-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
}

/* ===================================
   ГЕОЛОКАЦИЯ
   =================================== */
.hero__location {
  font-size: clamp(0.9rem, 2vw, 1.1rem);
  color: var(--text-gray);
  margin-top: 10px;
}

/* ===================================
   СЧЁТЧИК ГОСТЕЙ
   =================================== */
.hero__counter {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-top: 5px;
  flex-wrap: wrap;
}

.hero__counter-number {
  font-family: var(--font-pixel);
  font-size: clamp(1.2rem, 3vw, 1.8rem);
  color: var(--accent-yellow);
  text-shadow: var(--glow-yellow);
  animation: counterPulse 3s infinite;
}

.hero__counter-text {
  font-size: clamp(0.85rem, 2vw, 1.05rem);
  color: var(--text-gray);
}

@keyframes counterPulse {
  0%, 100% {
    text-shadow: var(--glow-yellow);
  }
  50% {
    text-shadow: var(--glow-yellow-strong);
  }
}

/* ===================================
   ПАРАЛЛАКС ЭФФЕКТ (через CSS)
   =================================== */
@media (min-width: 769px) {
  .hero {
    background-attachment: fixed;
  }
}

/* ===================================
   MEDIA QUERIES — АДАПТИВНОСТЬ
   =================================== */
/* Планшет */
@media (max-width: 1024px) {
  .hero__content {
    padding: 100px 20px 60px;
    gap: 25px;
  }

  .hero__tags {
    gap: 12px;
  }

  .hero__tag-card {
    min-width: 95px;
    padding: 16px 12px;
  }

  .hero__tag-icon {
    width: 36px;
    height: 36px;
  }

  .hero__tag-text {
    font-size: 0.5rem;
  }
}

/* Мобильные устройства */
@media (max-width: 768px) {
  .hero__content {
    padding: 90px 15px 50px;
    gap: 20px;
  }

  .hero__tags {
    gap: 8px;
  }

  .hero__tag {
    padding: 8px 15px;
    font-size: 0.8rem;
  }

  .hero__cta-btn {
    padding: 15px 35px;
  }
}

/* Маленькие мобильные */
@media (max-width: 480px) {
  .hero__content {
    padding: 80px 10px 40px;
    gap: 15px;
  }

  .hero__title {
    font-size: 2.2rem;
  }

  .hero__typed {
    font-size: 0.85rem;
  }

  .hero__tags {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    width: 100%;
    max-width: 380px;
    overflow-x: visible;
    padding: 5px 0;
  }

  .hero__tag-card {
    min-width: unset;
    padding: 15px 10px;
    gap: 8px;
  }

  .hero__tag-icon {
    width: 32px;
    height: 32px;
  }

  .hero__tag-text {
    font-size: 0.45rem;
  }

  .hero__cta-btn {
    padding: 12px 25px;
    font-size: 0.9rem;
    width: 100%;
    max-width: 300px;
  }
}
