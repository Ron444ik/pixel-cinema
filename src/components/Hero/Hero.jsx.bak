import { useState, useEffect, useRef } from 'react'
import { gsap } from 'gsap'
import Typed from 'typed.js'
import './Hero.css'

// Компонент анимированного счётчика
const AnimatedCounter = ({ target, duration = 2000 }) => {
  const [count, setCount] = useState(0)
  const counterRef = useRef(null)

  useEffect(() => {
    setCount(0)
    let start = 0
    const increment = target / (duration / 16)
    const timer = setInterval(() => {
      start += increment
      if (start >= target) {
        setCount(target)
        clearInterval(timer)
      } else {
        setCount(Math.floor(start))
      }
    }, 16)
    return () => clearInterval(timer)
  }, [target, duration])

  return <span ref={counterRef}>{count.toLocaleString('ru-RU')}</span>
}

const Hero = () => {
  // Реф для Typed.js
  const typedRef = useRef(null)
  
  // Рефы для GSAP анимации
  const heroRef = useRef(null)
  const subtitleRef = useRef(null)
  const titleRef = useRef(null)
  const tagsRef = useRef(null)
  const buttonRef = useRef(null)
  const locationRef = useRef(null)

  // Typed.js — печатающийся текст
  useEffect(() => {
    if (typedRef.current) {
      const typed = new Typed(typedRef.current, {
        strings: ['Кино', 'Игры', 'Караоке', 'Вечеринки', 'Дни рождения'],
        typeSpeed: 60,
        backSpeed: 40,
        backDelay: 1500,
        loop: true,
        showCursor: true,
        cursorChar: '|',
      })

      return () => {
        typed.destroy()
      }
    }
  }, [])

  // GSAP анимации при загрузке страницы
  useEffect(() => {
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } })

    tl.fromTo(
      subtitleRef.current,
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 0.8 }
    )
      .fromTo(
        titleRef.current,
        { opacity: 0, scale: 0.5 },
        { opacity: 1, scale: 1, duration: 1 },
        '-=0.4'
      )
      .fromTo(
        tagsRef.current,
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 0.8 },
        '-=0.5'
      )
      .fromTo(
        buttonRef.current,
        { opacity: 0, y: 30 },
        { opacity: 1, y: 0, duration: 0.6 },
        '-=0.4'
      )
      .fromTo(
        locationRef.current,
        { opacity: 0 },
        { opacity: 1, duration: 0.6 },
        '-=0.3'
      )

    return () => {
      tl.kill()
    }
  }, [])

  // Функция скролла к форме бронирования
  const handleBookingClick = () => {
    const bookingSection = document.getElementById('booking')
    if (bookingSection) {
      bookingSection.scrollIntoView({ behavior: 'smooth' })
    }
  }

  return (
    <section className="hero" ref={heroRef}>
      {/* Анимированные пиксели на фоне через CSS */}
      <div className="hero__pixels-bg">
        {Array.from({ length: 30 }).map((_, i) => (
          <div
            key={i}
            className="hero__pixel"
            style={{
              left: `${Math.random() * 100}%`,
              animationDelay: `${Math.random() * 5}s`,
              animationDuration: `${4 + Math.random() * 6}s`,
              opacity: 0.2 + Math.random() * 0.4,
              width: `${3 + Math.random() * 4}px`,
              height: `${3 + Math.random() * 4}px`,
            }}
          />
        ))}
      </div>

      {/* Тёмный overlay поверх фона */}
      <div className="hero__overlay"></div>

      {/* Контент Hero */}
      <div className="hero__content container">
        {/* Маленький текст сверху */}
        <p className="hero__subtitle" ref={subtitleRef}>
          ПЕРВЫЙ АНТИКИНОТЕАТР В ЯРОСЛАВЛЕ
        </p>

        {/* Огромный заголовок PIXEL с glitch анимацией */}
        <h1 className="hero__title glitch-text" ref={titleRef}>
          PIXEL
        </h1>

        {/* Typed.js — печатающийся текст */}
        <div className="hero__typed-wrapper">
          <span ref={typedRef} className="hero__typed"></span>
        </div>

        {/* Теги услуг — пиксельные карточки */}
        <div className="hero__tags" ref={tagsRef}>
          {/* Кино */}
          <div className="hero__tag-card">
            <svg className="hero__tag-icon" viewBox="0 0 24 24" fill="none">
              <rect x="2" y="6" width="14" height="12" rx="1" fill="#FFD700"/>
              <rect x="16" y="4" width="6" height="8" rx="1" fill="#FFD700"/>
              <circle cx="9" cy="10" r="3" fill="#0d0d0d"/>
              <circle cx="16" cy="6" r="1.5" fill="#0d0d0d"/>
              <circle cx="20" cy="6" r="1.5" fill="#0d0d0d"/>
              <circle cx="16" cy="10" r="1.5" fill="#0d0d0d"/>
              <circle cx="20" cy="10" r="1.5" fill="#0d0d0d"/>
              <rect x="16" y="14" width="6" height="2" fill="#0d0d0d"/>
            </svg>
            <span className="hero__tag-text">Кино</span>
          </div>

          {/* PS4/PS5 */}
          <div className="hero__tag-card">
            <svg className="hero__tag-icon" viewBox="0 0 24 24" fill="none">
              <rect x="2" y="8" width="20" height="8" rx="4" fill="#FFD700"/>
              <circle cx="7" cy="12" r="2" fill="#0d0d0d"/>
              <circle cx="17" cy="12" r="2" fill="#0d0d0d"/>
              <rect x="9" y="11" width="2" height="2" fill="#0d0d0d"/>
              <rect x="13" y="11" width="2" height="2" fill="#0d0d0d"/>
              <rect x="10" y="4" width="4" height="4" rx="1" fill="#FFD700"/>
            </svg>
            <span className="hero__tag-text">PS4/PS5</span>
          </div>

          {/* Караоке */}
          <div className="hero__tag-card">
            <svg className="hero__tag-icon" viewBox="0 0 24 24" fill="none">
              <circle cx="10" cy="14" r="5" fill="#FFD700"/>
              <circle cx="10" cy="14" r="2" fill="#0d0d0d"/>
              <rect x="14" y="4" width="2" height="12" fill="#FFD700"/>
              <rect x="12" y="4" width="6" height="3" fill="#FFD700"/>
              <rect x="6" y="18" width="8" height="2" fill="#FFD700"/>
            </svg>
            <span className="hero__tag-text">Караоке</span>
          </div>

          {/* Своя еда */}
          <div className="hero__tag-card">
            <svg className="hero__tag-icon" viewBox="0 0 24 24" fill="none">
              <path d="M2 12C2 6 8 2 12 2C16 2 22 6 22 12L12 22L2 12Z" fill="#FFD700"/>
              <circle cx="8" cy="10" r="1.5" fill="#0d0d0d"/>
              <circle cx="14" cy="8" r="1.5" fill="#0d0d0d"/>
              <circle cx="10" cy="14" r="1.5" fill="#0d0d0d"/>
            </svg>
            <span className="hero__tag-text">Своя еда</span>
          </div>

          {/* Настолки */}
          <div className="hero__tag-card">
            <svg className="hero__tag-icon" viewBox="0 0 24 24" fill="none">
              <rect x="3" y="3" width="7" height="7" rx="1" fill="#FFD700"/>
              <circle cx="6.5" cy="6.5" r="1.5" fill="#0d0d0d"/>
              <rect x="14" y="3" width="7" height="7" rx="1" fill="#FFD700"/>
              <circle cx="17.5" cy="5" r="1" fill="#0d0d0d"/>
              <circle cx="15.5" cy="8" r="1" fill="#0d0d0d"/>
              <circle cx="19.5" cy="8" r="1" fill="#0d0d0d"/>
              <rect x="3" y="14" width="7" height="7" rx="1" fill="#FFD700"/>
              <circle cx="5" cy="16.5" r="1" fill="#0d0d0d"/>
              <circle cx="8" cy="16.5" r="1" fill="#0d0d0d"/>
              <circle cx="6.5" cy="19" r="1" fill="#0d0d0d"/>
              <rect x="14" y="14" width="7" height="7" rx="1" fill="#FFD700"/>
              <circle cx="17.5" cy="17.5" r="1.5" fill="#0d0d0d"/>
            </svg>
            <span className="hero__tag-text">Настолки</span>
          </div>

          {/* Праздники */}
          <div className="hero__tag-card">
            <svg className="hero__tag-icon" viewBox="0 0 24 24" fill="none">
              <polygon points="12,2 14,10 22,10 16,15 18,22 12,18 6,22 8,15 2,10 10,10" fill="#FFD700"/>
              <circle cx="8" cy="6" r="1.5" fill="#FFD700"/>
              <circle cx="18" cy="4" r="1" fill="#FFD700"/>
              <circle cx="4" cy="14" r="1" fill="#FFD700"/>
              <circle cx="20" cy="14" r="1.5" fill="#FFD700"/>
              <circle cx="10" cy="20" r="1" fill="#FFD700"/>
            </svg>
            <span className="hero__tag-text">Праздники</span>
          </div>
        </div>

        {/* Большая жёлтая кнопка */}
        <button
          className="hero__cta-btn glow-btn"
          ref={buttonRef}
          onClick={handleBookingClick}
        >
          Забронировать зал
        </button>

        {/* Под кнопкой текст */}
        <p className="hero__payment-info" ref={locationRef}>
          Оплата только за время
        </p>

        {/* Анимированный счётчик гостей */}
        <div className="hero__counter" ref={locationRef}>
          <span className="hero__counter-number">
            <AnimatedCounter target={1247} />+
          </span>
          <span className="hero__counter-text">довольных гостей</span>
        </div>
      </div>
    </section>
  )
}

export default Hero
